# ===========================================
# Sistema de Reservas - Environment Variables
# ===========================================
# Copy this file to .env and adjust values.
# NEVER commit .env to version control.

# --- MySQL Container ---
# Root password for the MySQL server.
MYSQL_ROOT_PASSWORD=rootpassword

# Database created automatically on first container start.
MYSQL_DATABASE=reservas_db

# Optional dedicated application user (not used as root).
MYSQL_USER=reservas_user
MYSQL_PASSWORD=reservas_pass

# --- Backend DB Connection ---
# DB_HOST is "db" inside Docker Compose, "localhost" for local dev.
DB_HOST=db
DB_PORT=3306
DB_NAME=reservas_db

# Use the MySQL user defined above (or root for local dev).
DB_USER=reservas_user
DB_PASSWORD=reservas_pass

# --- JWT ---
# Dev-only secret. MUST be at least 32 characters and changed in production.
JWT_SECRET=ZmFrZS1zZWNyZXQta2V5LWZvci1kZXYtb25seS1jaGFuZ2UtaW4tcHJvZHVjdGlvbi1wbGVhc2UtbWluLTMyLWNoYXJz
JWT_EXPIRATION_HOURS=1
JWT_ISSUER=reservas-app

# --- Rate Limiting ---
RATELIMIT_MAX_ATTEMPTS=5
RATELIMIT_WINDOW_SECONDS=60
RATELIMIT_LOCKOUT_MINUTES=15
